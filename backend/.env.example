# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://wfm:wfmpassword@localhost:5432/wfm_request_portal?schema=public

# Auth (local JWT)
JWT_SECRET=change-this-super-secret-key-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d
SESSION_TIMEOUT_MINUTES=30
BCRYPT_SALT_ROUNDS=10

# Azure AD (ready for later - leave blank to keep local auth only)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=

# File storage
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20
# Azure Blob (ready for later)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments

# Email (dev transport by default - logs to console + /emails folder)
EMAIL_DRIVER=dev
EMAIL_FROM="WFM Request Portal <no-reply@wfm-portal.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# CORS
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5190

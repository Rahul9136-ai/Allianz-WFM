    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.13.4",
